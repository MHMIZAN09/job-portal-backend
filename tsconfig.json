{
  "compilerOptions": {
    "module": "ESNext",
    "target": "ES2023",
    "rootDir": "./src",
    "outDir": "./dist",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "generated"
  ]
}
