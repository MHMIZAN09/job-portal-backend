<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <title>Verify Your Email - Job Portal</title>
</head>
<body style="margin: 0; padding: 0; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f4f6f9;">

  <!-- Main Wrapper -->
  <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background-color: #f4f6f9; padding: 40px 20px;">
    <tr>
      <td align="center">

        <!-- Email Card -->
        <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="600" style="max-width: 600px; background-color: #ffffff; border-radius: 16px; overflow: hidden; box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08);">

          <!-- Header with Gradient -->
          <tr>
            <td style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 40px 30px; text-align: center;">
              <!-- Icon Circle -->
              <div style="display: inline-block; background-color: rgba(255, 255, 255, 0.2); width: 70px; height: 70px; border-radius: 50%; line-height: 70px; margin-bottom: 16px;">
                <span style="font-size: 32px;">🔐</span>
              </div>
              <h1 style="color: #ffffff; margin: 0; font-size: 28px; font-weight: 700; letter-spacing: -0.5px;">
                Verify Your Email
              </h1>
              <p style="color: rgba(255, 255, 255, 0.9); margin: 8px 0 0; font-size: 15px;">
                💼 Job Portal - Your Career Awaits
              </p>
            </td>
          </tr>

          <!-- Body Content -->
          <tr>
            <td style="padding: 40px 40px 20px;">
              <h2 style="color: #1a202c; margin: 0 0 16px; font-size: 22px; font-weight: 600;">
                Hello <%= name %>! 👋
              </h2>
              <p style="color: #4a5568; line-height: 1.6; margin: 0 0 24px; font-size: 15px;">
                Thank you for joining <strong>Job Portal</strong>! To complete your registration and secure your account, please use the verification code below.
              </p>

              <!-- OTP Code Box -->
              <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="margin: 32px 0;">
                <tr>
                  <td align="center">
                    <div style="background: linear-gradient(135deg, #f6f9fc 0%, #eef2f7 100%); border: 2px dashed #cbd5e0; border-radius: 12px; padding: 24px 40px; display: inline-block;">
                      <p style="color: #718096; margin: 0 0 8px; font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 1.5px;">
                        Your Verification Code
                      </p>
                      <div style="font-size: 42px; font-weight: 700; color: #2d3748; letter-spacing: 12px; font-family: 'Courier New', monospace;">
                        <%= otp %>
                      </div>
                    </div>
                  </td>
                </tr>
              </table>

              <!-- Expiry Warning -->
              <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%" style="background-color: #fff5f5; border-left: 4px solid #fc8181; border-radius: 6px; margin: 24px 0;">
                <tr>
                  <td style="padding: 16px 20px;">
                    <p style="color: #c53030; margin: 0; font-size: 14px; line-height: 1.5;">
                      <strong>⏱️ Important:</strong> This OTP will expire in <strong>2 minutes</strong>. Please use it before it expires.
                    </p>
                  </td>
                </tr>
              </table>

              <!-- Security Tips Box -->
              <div style="background-color: #f7fafc; border-radius: 8px; padding: 20px; margin: 24px 0;">
                <p style="color: #4a5568; margin: 0 0 12px; font-size: 14px; font-weight: 600;">
                  🛡️ Security Tips
                </p>
                <ul style="color: #718096; margin: 0; padding-left: 20px; font-size: 13px; line-height: 1.8;">
                  <li>Never share this OTP with anyone</li>
                  <li>Our team will never ask for your verification code</li>
                  <li>If you didn't request this, please ignore this email</li>
                </ul>
              </div>

              <p style="color: #4a5568; line-height: 1.6; margin: 24px 0 0; font-size: 14px;">
                If you're having trouble or have any questions, contact our support team at
                <a href="mailto:support@jobportal.com" style="color: #667eea; text-decoration: none; font-weight: 600;">support@jobportal.com</a>
              </p>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="background-color: #f7fafc; padding: 30px 40px; text-align: center; border-top: 1px solid #e2e8f0;">
              <p style="color: #2d3748; margin: 0 0 8px; font-size: 14px; font-weight: 600;">
                💼 Job Portal
              </p>
              <p style="color: #718096; margin: 0 0 12px; font-size: 12px;">
                © <%= new Date().getFullYear() %> Job Portal. All rights reserved.
              </p>

              <!-- Social Links -->
              <div style="margin-top: 12px;">
                <a href="#" style="color: #667eea; text-decoration: none; margin: 0 8px; font-size: 12px;">Website</a>
                <span style="color: #cbd5e0;">|</span>
                <a href="#" style="color: #667eea; text-decoration: none; margin: 0 8px; font-size: 12px;">Privacy Policy</a>
                <span style="color: #cbd5e0;">|</span>
                <a href="#" style="color: #667eea; text-decoration: none; margin: 0 8px; font-size: 12px;">Terms of Service</a>
              </div>

              <p style="color: #a0aec0; margin: 16px 0 0; font-size: 11px;">
                This is an automated email. Please do not reply directly.
              </p>
            </td>
          </tr>

        </table>

        <!-- Outside Footer Note -->
        <p style="color: #a0aec0; margin: 20px 0 0; font-size: 11px; text-align: center;">
          Sent to you because you registered at Job Portal
        </p>

      </td>
    </tr>
  </table>

</body>
</html>
