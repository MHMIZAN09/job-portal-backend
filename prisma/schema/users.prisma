model User {
  id           String  @id @default(uuid(7))
  name         String
  email        String  @unique
  password     String
  role         Role    @default(JOB_SEEKER)
  phone        String?
  profileImage String?
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email], name: "email_index")
  @@map("users")
}

enum Role {
  JOB_SEEKER
  EMPLOYER
  ADMIN
}
