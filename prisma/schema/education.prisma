model Education {
  id          String           @id @default(uuid(7))
  jobSeekerId String
  jobSeeker   JobSeekerProfile @relation(fields: [jobSeekerId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  degree       String
  institution  String
  fieldOfStudy String?
  startDate    DateTime
  endDate      DateTime?
  cgpa         Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobSeekerId])
  @@map("educations")
}
